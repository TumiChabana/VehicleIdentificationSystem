<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.vis.controller.DashboardController"
           styleClass="root-pane"
           stylesheets="@../styles/dashboard.css">

    <BorderPane styleClass="root-pane">
    <!-- ═══ TOP — MenuBar + Header ═══ -->
    <top>
        <VBox>

            <!-- Menu Bar -->
            <MenuBar styleClass="menu-bar">
                <Menu text="File">
                    <MenuItem text="Refresh Data"
                              onAction="#handleRefresh"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit"
                              onAction="#handleExit"/>
                </Menu>
                <Menu text="Modules">
                    <MenuItem text="Workshop"
                              onAction="#openWorkshop"/>
                    <MenuItem text="Customer"
                              onAction="#openCustomer"/>
                    <MenuItem text="Police"
                              onAction="#openPolice"/>
                    <MenuItem text="Insurance"
                              onAction="#openInsurance"/>
                </Menu>
                <Menu text="Reports">
                    <MenuItem text="Vehicle Report"/>
                    <MenuItem text="Violation Report"/>
                    <MenuItem text="Insurance Report"/>
                </Menu>
                <Menu text="Admin">
                    <MenuItem text="Manage Users"
                              onAction="#openAdmin"/>
                    <MenuItem text="System Settings"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About VIS"/>
                    <MenuItem text="Documentation"/>
                </Menu>
            </MenuBar>

            <!-- Header Bar -->
            <HBox styleClass="top-header"
                  alignment="CENTER_LEFT" spacing="20">
            <HBox spacing="9">
                <!-- Logo + Title -->
                <ImageView fitHeight="40" fitWidth="40"
                           pickOnBounds="true" preserveRatio="true" >
                    <image>
                        <Image url="/images/logo3.png"/>
                    </image>
                </ImageView>
                <VBox>
                    <Label text="NVis"
                           styleClass="header-title"/>
                    <Label fx:id="welcomeLabel"
                           text="Welcome"
                           styleClass="header-sub"/>
                </VBox>
            </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Progress Bar in header -->
                <VBox alignment="CENTER_RIGHT" spacing="4"
                      prefWidth="200">
                    <Label text="SYSTEM LOAD"
                           styleClass="progress-label"/>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <ProgressBar fx:id="systemProgressBar"
                                     progress="0.0"
                                     prefWidth="150"
                                     styleClass="progress-bar"/>
                        <ProgressIndicator
                                fx:id="dbProgressIndicator"
                                progress="-1"
                                prefWidth="24"
                                prefHeight="24"/>
                    </HBox>
                </VBox>

                <Separator orientation="VERTICAL"
                           styleClass="header-separator"/>

                <!-- Role + Date -->
                <VBox alignment="CENTER_RIGHT" spacing="4">
                    <Label fx:id="roleLabel"
                           text="ADMIN"
                           styleClass="role-badge"/>
                    <Label fx:id="dateLabel"
                           text="Loading..."
                           styleClass="header-date"/>
                </VBox>

                <!-- Logout -->

                <Button text="Logout"
                        styleClass="btn-danger"
                        onAction="#handleLogout"/>

            </HBox>

        </VBox>
    </top>

    <!-- ═══ CENTER — Main Content ═══ -->
    <center>
        <ScrollPane styleClass="scroll-pane"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED">

            <VBox styleClass="main-content" spacing="24">
                <padding>
                    <Insets top="28" right="32"
                            bottom="28" left="32"/>
                </padding>

                <!-- Page Title -->
                <VBox spacing="4">
                    <Label text="Dashboard Overview"
                           styleClass="page-title"/>
                    <Label text="Real-time system statistics"
                           styleClass="page-subtitle"/>
                </VBox>

                <!-- ── STAT CARDS ── -->


                <!-- ── VEHICLES TABLE ── -->
                <VBox styleClass="stat-card" spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Registered Vehicles"
                                   styleClass="section-title"/>
                            <Label text="All vehicles in the system"
                                   styleClass="page-subtitle"/>
                        </VBox>
                        <Button fx:id="addVehicleBtn"
                                text="+ Add Vehicle"
                                styleClass="btn-primary"
                                onAction="#openWorkshop"/>
                    </HBox>

                    <TableView fx:id="vehicleTable"
                               styleClass="table-view"
                               prefHeight="260"
                               >
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colReg"
                                         text="Registration"
                                         />
                            <TableColumn fx:id="colMake"
                                         text="Make"
                                         />
                            <TableColumn fx:id="colModel"
                                         text="Model"
                                         />
                            <TableColumn fx:id="colYear"
                                         text="Year"
                                         />
                            <TableColumn fx:id="colColor"
                                         text="Color"
                                         />
                            <TableColumn fx:id="colOwner"
                                         text="Owner"
                                         />
                        </columns>
                        <placeholder>
                            <Label text="Loading vehicles..."
                                   style="-fx-text-fill: #555577;"/>
                        </placeholder>
                    </TableView>
                </VBox>

                <!-- ── BOTTOM ROW ── -->
                <HBox spacing="16" VBox.vgrow="ALWAYS">

                    <!-- Activity Feed -->
                    <VBox styleClass="stat-card" spacing="12"
                          HBox.hgrow="ALWAYS">
                        <Label text="Recent Activity"
                               styleClass="section-title"/>
                        <ScrollPane styleClass="scroll-pane"
                                    prefHeight="260"
                                    fitToWidth="true">
                            <VBox fx:id="activityList"
                                  spacing="8">
                                <padding>
                                    <Insets top="4" right="4"
                                            bottom="4" left="4"/>
                                </padding>
                            </VBox>
                        </ScrollPane>
                    </VBox>

                    <!-- Violations + Pagination -->
                    <VBox styleClass="stat-card" spacing="12"
                          HBox.hgrow="ALWAYS">
                        <Label text="Violations"
                               styleClass="section-title"/>
                        <TableView fx:id="violationTable"
                                   styleClass="table-view"
                                   prefHeight="200"
                                   >
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colViolationType"
                                             text="Type"
                                             />
                                <TableColumn fx:id="colViolationFine"
                                             text="Fine (M)"
                                             />
                                <TableColumn fx:id="colViolationStatus"
                                             text="Status"
                                             />
                            </columns>
                            <placeholder>
                                <Label text="No violations"
                                       style="-fx-text-fill: #555577;"/>
                            </placeholder>
                        </TableView>
                        <Pagination fx:id="violationPagination"
                                    pageCount="1"
                                    styleClass="pagination"/>
                    </VBox>

                </HBox>

            </VBox>
        </ScrollPane>
    </center>

    </BorderPane>

    <!-- ═══ VEHICLE DETAIL OVERLAY ═══ -->
    <StackPane fx:id="overlayPane"
               visible="false"
               mouseTransparent="false"
               pickOnBounds="false"
               style="-fx-background-color: transparent;">

        <!-- Semi-transparent full-screen dimmer -->
        <Region style="-fx-background-color: rgba(5,5,18,0.55);"
                pickOnBounds="false"/>

        <!-- Card anchored to top-right -->
        <VBox fx:id="vehicleDetailCard"
              styleClass="vehicle-detail-card"
              prefWidth="340"
              maxWidth="340"
              spacing="0"
              StackPane.alignment="TOP_RIGHT">

            <!-- Image sits at the very top, fixed height -->
            <ImageView fx:id="overlayCarImage"
                       fitWidth="340"
                       fitHeight="210"
                       preserveRatio="false"
                       smooth="true"
                       managed="true"
                       visible="true">
                <VBox.margin>
                    <Insets top="0" right="0" bottom="0" left="0"/>
                </VBox.margin>
            </ImageView>

            <VBox styleClass="detail-card-body" spacing="10">
                <padding>
                    <Insets top="18" right="20" bottom="22" left="20"/>
                </padding>

                <Label text="VEHICLE DETAILS"
                       styleClass="detail-card-title"/>

                <HBox styleClass="detail-row" spacing="8">
                    <Label text="REG"    styleClass="detail-key"/>
                    <Label fx:id="overlayReg"   styleClass="detail-value"/>
                </HBox>
                <HBox styleClass="detail-row" spacing="8">
                    <Label text="MAKE"   styleClass="detail-key"/>
                    <Label fx:id="overlayMake"  styleClass="detail-value"/>
                </HBox>
                <HBox styleClass="detail-row" spacing="8">
                    <Label text="MODEL"  styleClass="detail-key"/>
                    <Label fx:id="overlayModel" styleClass="detail-value"/>
                </HBox>
                <HBox styleClass="detail-row" spacing="8">
                    <Label text="YEAR"   styleClass="detail-key"/>
                    <Label fx:id="overlayYear"  styleClass="detail-value"/>
                </HBox>
                <HBox styleClass="detail-row" spacing="8">
                    <Label text="COLOR"  styleClass="detail-key"/>
                    <Label fx:id="overlayColor" styleClass="detail-value"/>
                </HBox>
                <HBox styleClass="detail-row" spacing="8">
                    <Label text="OWNER"  styleClass="detail-key"/>
                    <Label fx:id="overlayOwner" styleClass="detail-value"/>
                </HBox>

                <Button text="CLOSE"
                        styleClass="btn-danger"
                        onAction="#hideVehicleOverlay"
                        maxWidth="Infinity"/>
            </VBox>
        </VBox>

    </StackPane>
</StackPane>
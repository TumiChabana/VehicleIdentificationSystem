<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.vis.controller.CustomerController"
            styleClass="root-pane"
            stylesheets="@../styles/customer.css">
    <top>
        <VBox>
            <MenuBar fx:id="customerMenuBar" styleClass="menu-bar">
                <Menu text="File">
                    <MenuItem text="Refresh"
                              onAction="#handleRefresh"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit"
                              onAction="#handleExit"/>
                </Menu>
                <Menu text="Modules">
                    <MenuItem text="Dashboard"
                              onAction="#goToDashboard"/>
                    <MenuItem text="Workshop"
                              onAction="#openWorkshop"/>
                    <MenuItem text="Police"
                              onAction="#openPolice"/>
                    <MenuItem text="Insurance"
                              onAction="#openInsurance"/>
                </Menu>
            </MenuBar>

            <HBox styleClass="top-header"
                  alignment="CENTER_LEFT" spacing="20">
                <HBox spacing="9">
                    <!-- Logo + Title -->
                    <ImageView fitHeight="40" fitWidth="40"
                               pickOnBounds="true" preserveRatio="true" >
                        <image>
                            <Image url="/images/logo3.png"/>
                        </image>
                    </ImageView>

                    <VBox>
                        <Label fx:id="moduleTitleLabel"
                               text="CUSTOMER MODULE"
                               styleClass="header-title"/>
                        <Label fx:id="moduleSubLabel"
                               text="Owner Information &amp; Queries"
                               styleClass="header-sub"/>
                    </VBox>

                </HBox>

                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userLabel"
                       text="" styleClass="role-badge"/>
                <Button fx:id="dashboardBtn"
                        text="Dashboard"
                        styleClass="btn-secondary"
                        onAction="#goToDashboard"/>
                <Button text="Logout"
                        styleClass="btn-danger"
                        onAction="#handleLogout"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox styleClass="main-content">
            <TabPane fx:id="customerTabs"
                     styleClass="module-tabs"
                     VBox.vgrow="ALWAYS">

                <!-- ══ TAB 1 — CUSTOMERS (Admin) / MY PROFILE (Customer) ══ -->
                <Tab fx:id="tab1"
                     text="Customers"
                     closable="false">
                    <SplitPane fx:id="customerSplitPane" dividerPositions="0.62"
                               styleClass="split-pane" VBox.vgrow="ALWAYS"
                               maxWidth="Infinity"
                               maxHeight="Infinity">

                        <!-- LEFT: Table (Admin) / Profile Card (Customer) -->
                        <VBox fx:id="adminCustomerPanel"
                              styleClass="panel-card" spacing="14">
                            <padding>
                                <Insets top="20" right="20"
                                        bottom="20" left="20"/>
                            </padding>

                            <!-- ADMIN SEARCH (hidden for customer) -->
                            <HBox fx:id="adminSearchBar"
                                  spacing="12"
                                  alignment="CENTER_LEFT">
                                <TextField fx:id="customerSearchField"
                                           promptText="Search..."
                                           styleClass="form-field"
                                           HBox.hgrow="ALWAYS"
                                           onKeyReleased="#handleCustomerSearch"/>
                                <Button text="Add Customer"
                                        styleClass="btn-primary"
                                        onAction="#handleAddCustomer"/>
                                <Button text="Clear"
                                        styleClass="btn-secondary"
                                        onAction="#handleClearCustomer"/>
                            </HBox>

                            <!-- CUSTOMER PROFILE CARD (hidden for admin) -->
                            <VBox fx:id="customerProfileCard"
                                  styleClass="stat-card"
                                  spacing="16"
                                  visible="false"
                                  managed="false">
                                <Label text="MY PROFILE"
                                       styleClass="section-title"/>
                                <HBox styleClass="detail-row" spacing="8">
                                    <Label text="NAME"
                                           styleClass="detail-key"
                                           minWidth="80"/>
                                    <Label fx:id="profileName"
                                           text=":"
                                           styleClass="detail-value"/>
                                </HBox>
                                <HBox styleClass="detail-row" spacing="8">
                                    <Label text="PHONE"
                                           styleClass="detail-key"
                                           minWidth="80"/>
                                    <Label fx:id="profilePhone"
                                           text=":"
                                           styleClass="detail-value"/>
                                </HBox>
                                <HBox styleClass="detail-row" spacing="8">
                                    <Label text="EMAIL"
                                           styleClass="detail-key"
                                           minWidth="80"/>
                                    <Label fx:id="profileEmail"
                                           text=":"
                                           styleClass="detail-value"/>
                                </HBox>
                                <HBox styleClass="detail-row" spacing="8">
                                    <Label text="ADDRESS"
                                           styleClass="detail-key"
                                           minWidth="80"/>
                                    <Label fx:id="profileAddress"
                                           text=":"
                                           styleClass="detail-value"
                                           wrapText="true"/>
                                </HBox>
                            </VBox>

                            <!-- SHARED TABLE -->
                            <TableView fx:id="customerTable"
                                       styleClass="table-view"
                                       VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colName"
                                                 text="Name"/>
                                    <TableColumn fx:id="colPhone"
                                                 text="Phone"/>
                                    <TableColumn fx:id="colEmail"
                                                 text="Email"/>
                                    <TableColumn fx:id="colAddress"
                                                 text="Address"/>
                                </columns>
                                <placeholder>
                                    <Label text="No customers found"
                                           style="-fx-text-fill: #555577;"/>
                                </placeholder>
                            </TableView>

                            <!-- ADMIN ACTIONS (hidden for customer) -->
                            <HBox fx:id="adminCustomerActions"
                                  spacing="10">
                                <Button text="Edit Selected"
                                        styleClass="btn-secondary"
                                        onAction="#handleEditCustomer"/>
                                <Button text="Delete Selected"
                                        styleClass="btn-danger"
                                        onAction="#handleDeleteCustomer"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="customerStatusLabel"
                                       text=""
                                       styleClass="success-label"/>
                            </HBox>
                        </VBox>

                        <!-- RIGHT: Form (Admin) / My Vehicles (Customer) -->
                        <ScrollPane styleClass="scroll-pane"
                                    fitToWidth="true"
                                    fitToHeight="true"
                                    SplitPane.resizableWithParent="true">
                            <VBox SplitPane.resizableWithParent="true"
                                  VBox.vgrow="ALWAYS"
                                  maxHeight="Infinity"
                                  minHeight="0">
                            <!-- ADMIN FORM -->
                            <VBox fx:id="adminCustomerForm"
                                  styleClass="panel-card"
                                  spacing="16"
                                  VBox.vgrow="ALWAYS"
                                  maxHeight="Infinity"
                                  minHeight="0">
                                <padding>
                                    <Insets top="20" right="24"
                                            bottom="20" left="24"/>
                                </padding>

                                <Label fx:id="customerFormTitle"
                                       text="Add New Customer"
                                       styleClass="section-title"/>

                                <Label text="FULL NAME"
                                       styleClass="field-label"/>
                                <TextField fx:id="fieldName"
                                           promptText="e.g. Karabo Tlali"
                                           styleClass="form-field"/>

                                <Label text="PHONE NUMBER"
                                       styleClass="field-label"/>
                                <TextField fx:id="fieldPhone"
                                           promptText="e.g. +266 5812 3456"
                                           styleClass="form-field"/>

                                <Label text="EMAIL ADDRESS"
                                       styleClass="field-label"/>
                                <TextField fx:id="fieldEmail"
                                           promptText="e.g. name@yahoo.com"
                                           styleClass="form-field"/>

                                <Label text="ADDRESS"
                                       styleClass="field-label"/>
                                <TextArea fx:id="fieldAddress"
                                          promptText="e.g. 12 Moshoeshoe Rd"
                                          styleClass="form-field"
                                          prefHeight="80"
                                          wrapText="true"
                                          VBox.vgrow="ALWAYS"/>

                                <Button fx:id="customerSaveBtn"
                                        text="SAVE CUSTOMER"
                                        styleClass="btn-primary"
                                        maxWidth="Infinity"
                                        onAction="#handleSaveCustomer"/>

                                <Label fx:id="customerFormStatus"
                                       text=""
                                       styleClass="success-label"
                                       wrapText="true"/>
                            </VBox>

                            <!-- CUSTOMER VEHICLE CARDS
                                 (shown only for customer role) -->
                            <VBox fx:id="myVehiclesPanel"
                                  styleClass="panel-card"
                                  spacing="16"
                                  visible="false"
                                  managed="false">
                                <padding>
                                    <Insets top="20" right="24"
                                            bottom="20" left="24"/>
                                </padding>
                                <Label text="MY VEHICLES"
                                       styleClass="section-title"/>
                                <Label text="Vehicles registered under your name"
                                       styleClass="page-subtitle"/>
                                <VBox fx:id="myVehiclesList"
                                      spacing="12"/>
                            </VBox>
                            </VBox>

                        </ScrollPane>
                    </SplitPane>
                </Tab>

                <!-- ══ TAB 2 — QUERIES ══ -->
                <Tab text="Queries" closable="false">
                    <SplitPane dividerPositions="0.62"
                               styleClass="split-pane">

                        <VBox styleClass="panel-card" spacing="14">
                            <padding>
                                <Insets top="20" right="20"
                                        bottom="20" left="20"/>
                            </padding>

                            <HBox spacing="12"
                                  alignment="CENTER_LEFT">
                                <ComboBox fx:id="queryCustomerFilter"
                                          promptText="Filter by customer..."
                                          styleClass="form-combo"
                                          prefWidth="240"
                                          onAction="#handleQueryFilter"/>
                                <Button text="New Query"
                                        styleClass="btn-primary"
                                        onAction="#handleNewQuery"/>
                                <Button text="Clear"
                                        styleClass="btn-secondary"
                                        onAction="#handleClearQuery"/>
                            </HBox>

                            <TableView fx:id="queryTable"
                                       styleClass="table-view"
                                       VBox.vgrow="ALWAYS"
                                       onMouseClicked="#handleQuerySelected">
                                <columns>
                                    <TableColumn fx:id="colQCustomer"
                                                 text="Customer"/>
                                    <TableColumn fx:id="colQVehicle"
                                                 text="Vehicle"/>
                                    <TableColumn fx:id="colQDate"
                                                 text="Date"/>
                                    <TableColumn fx:id="colQStatus"
                                                 text="Status"/>
                                    <TableColumn fx:id="colQText"
                                                 text="Query"/>
                                </columns>
                                <placeholder>
                                    <Label text="No queries yet"
                                           style="-fx-text-fill: #555577;"/>
                                </placeholder>
                            </TableView>

                            <Pagination fx:id="queryPagination"
                                        pageCount="1"
                                        styleClass="pagination"/>

                            <HBox spacing="10">
                                <Button fx:id="deleteQueryBtn"
                                        text="Delete"
                                        styleClass="btn-danger"
                                        onAction="#handleDeleteQuery"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="queryStatusLabel"
                                       text=""
                                       styleClass="success-label"/>
                            </HBox>
                        </VBox>

                        <ScrollPane styleClass="scroll-pane"
                                    fitToWidth="true">
                            <VBox styleClass="panel-card"
                                  spacing="16">
                                <padding>
                                    <Insets top="20" right="24"
                                            bottom="20" left="24"/>
                                </padding>

                                <Label fx:id="queryFormTitle"
                                       text="File a Query"
                                       styleClass="section-title"/>
                                <Label text="Ask about your vehicle's condition or status"
                                       styleClass="page-subtitle"
                                       wrapText="true"/>

                                <Label text="CUSTOMER"
                                       styleClass="field-label"/>
                                <ComboBox fx:id="queryCustomerCombo"
                                          promptText="Select customer..."
                                          styleClass="form-combo"
                                          maxWidth="Infinity"/>

                                <Label text="VEHICLE"
                                       styleClass="field-label"/>
                                <ComboBox fx:id="queryVehicleCombo"
                                          promptText="Select vehicle..."
                                          styleClass="form-combo"
                                          maxWidth="Infinity"/>

                                <Label text="DATE"
                                       styleClass="field-label"/>
                                <DatePicker fx:id="queryDatePicker"
                                            styleClass="form-date"
                                            maxWidth="Infinity"/>

                                <Label text="YOUR QUERY"
                                       styleClass="field-label"/>
                                <TextArea fx:id="queryTextField"
                                          promptText="Describe your question or concern..."
                                          styleClass="form-field"
                                          prefHeight="100"
                                          wrapText="true"/>

                                <!-- Response area — shown when
                                     admin responds -->
                                <VBox fx:id="responseArea"
                                      spacing="8">
                                    <Label text="RESPONSE FROM SYSTEM"
                                           styleClass="field-label"/>
                                    <TextArea fx:id="responseTextField"
                                              promptText="Response will appear here..."
                                              styleClass="form-field"
                                              prefHeight="80"
                                              wrapText="true"/>
                                </VBox>

                                <HBox spacing="10">
                                    <Button fx:id="saveQueryBtn"
                                            text="SUBMIT QUERY"
                                            styleClass="btn-primary"
                                            HBox.hgrow="ALWAYS"
                                            maxWidth="Infinity"
                                            onAction="#handleSaveQuery"/>
                                    <Button fx:id="respondBtn"
                                            text="RESPOND"
                                            styleClass="btn-secondary"
                                            HBox.hgrow="ALWAYS"
                                            maxWidth="Infinity"
                                            onAction="#handleRespondQuery"
                                            visible="false"
                                            managed="false"/>
                                </HBox>

                                <Label fx:id="queryFormStatus"
                                       text=""
                                       styleClass="success-label"
                                       wrapText="true"/>
                            </VBox>
                        </ScrollPane>
                    </SplitPane>
                </Tab>

                <!-- ══ TAB 3 — MY SERVICES (Customer only) ══ -->
                <Tab fx:id="myServicesTab"
                     text="My Services"
                     closable="false"
                     >
                    <VBox styleClass="panel-card" spacing="14">
                        <padding>
                            <Insets top="20" right="20"
                                    bottom="20" left="20"/>
                        </padding>
                        <Label text="MY SERVICE HISTORY"
                               styleClass="section-title"/>
                        <Label text="All services performed on your vehicles"
                               styleClass="page-subtitle"/>
                        <TableView fx:id="myServicesTable"
                                   styleClass="table-view"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colSVehicle"
                                             text="Vehicle"/>
                                <TableColumn fx:id="colSDate"
                                             text="Date"/>
                                <TableColumn fx:id="colSType"
                                             text="Service Type"/>
                                <TableColumn fx:id="colSDesc"
                                             text="Description"/>
                                <TableColumn fx:id="colSCost"
                                             text="Cost (M)"/>
                            </columns>
                            <placeholder>
                                <Label text="No service records yet"
                                       style="-fx-text-fill: #555577;"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- ══ TAB 4 — MY INSURANCE (Customer only) ══ -->
                <Tab fx:id="myInsuranceTab"
                     text="My Insurance"
                     closable="false"
                     >
                    <VBox styleClass="panel-card" spacing="14">
                        <padding>
                            <Insets top="20" right="20"
                                    bottom="20" left="20"/>
                        </padding>
                        <Label text="MY INSURANCE POLICIES"
                               styleClass="section-title"/>
                        <Label text="Active and past insurance coverage"
                               styleClass="page-subtitle"/>
                        <TableView fx:id="myInsuranceTable"
                                   styleClass="table-view"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colIVehicle"
                                             text="Vehicle"/>
                                <TableColumn fx:id="colIProvider"
                                             text="Provider"/>
                                <TableColumn fx:id="colIPolicy"
                                             text="Policy No."/>
                                <TableColumn fx:id="colIStart"
                                             text="Start"/>
                                <TableColumn fx:id="colIEnd"
                                             text="Expiry"/>
                                <TableColumn fx:id="colIStatus"
                                             text="Status"/>
                            </columns>
                            <placeholder>
                                <Label text="No insurance policies found"
                                       style="-fx-text-fill: #555577;"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- TAB 5 — MY VIOLATIONS -->
                <Tab fx:id="myViolationsTab"
                     text="My Violations"
                     closable="false">
                    <VBox styleClass="panel-card" spacing="14">
                        <padding>
                            <Insets top="20" right="20"
                                    bottom="20" left="20"/>
                        </padding>
                        <Label text="MY VIOLATIONS"
                               styleClass="section-title"/>
                        <Label text="Fines and traffic violations on your vehicles"
                               styleClass="page-subtitle"/>
                        <TableView fx:id="myViolationsTable"
                                   styleClass="table-view"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colVVehicle"
                                             text="Vehicle"/>
                                <TableColumn fx:id="colVDate"
                                             text="Date"/>
                                <TableColumn fx:id="colVType"
                                             text="Violation"/>
                                <TableColumn fx:id="colVFine"
                                             text="Fine (M)"/>
                                <TableColumn fx:id="colVStatus"
                                             text="Status"/>
                            </columns>
                            <placeholder>
                                <Label text="No violations on your vehicles"
                                       style="-fx-text-fill: #44cc88;"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- TAB 6 — MY POLICE REPORTS -->
                <Tab fx:id="myPoliceReportsTab"
                     text="My Reports"
                     closable="false">

                    <!-- ← VBox must grow to fill tab -->
                    <VBox styleClass="panel-card" spacing="14"
                          maxWidth="Infinity" maxHeight="Infinity">
                        <padding>
                            <Insets top="20" right="20"
                                    bottom="20" left="20"/>
                        </padding>

                        <Label text="POLICE REPORTS ON MY VEHICLES"
                               styleClass="section-title"/>
                        <Label text="Accidents, theft cases and investigations"
                               styleClass="page-subtitle"/>

                        <!-- ← TableView must grow to fill VBox -->
                        <TableView fx:id="myPoliceReportsTable"
                                   styleClass="table-view"
                                   VBox.vgrow="ALWAYS"
                                   maxWidth="Infinity"
                                   maxHeight="Infinity">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colPVehicle"
                                             text="Vehicle"/>
                                <TableColumn fx:id="colPDate"
                                             text="Date"/>
                                <TableColumn fx:id="colPType"
                                             text="Type"/>
                                <TableColumn fx:id="colPOfficer"
                                             text="Officer Handling"/>
                                <TableColumn fx:id="colPDesc"
                                             text="Details"/>
                            </columns>
                            <placeholder>
                                <Label text="No police reports on your vehicles"
                                       style="-fx-text-fill: #44cc88;"/>
                            </placeholder>
                        </TableView>

                        <!-- Info card at bottom -->
                        <VBox styleClass="stat-card" spacing="8">
                            <Label text="The officer name shown is handling your case."
                                   styleClass="page-subtitle"
                                   wrapText="true"/>
                        </VBox>

                    </VBox>
                </Tab>

            </TabPane>
        </VBox>
    </center>

</BorderPane>
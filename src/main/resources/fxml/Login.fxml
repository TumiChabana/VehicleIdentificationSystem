<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.vis.controller.LoginController"
           styleClass="root-pane"
           stylesheets="@../styles/login.css">

    <HBox>

        <!-- LEFT — Branding -->
        <StackPane HBox.hgrow="ALWAYS" minWidth="520" maxWidth="640">

            <ImageView fitWidth="640" fitHeight="900" preserveRatio="false" >
                <image><Image url="@../images/car_bg.jpg" backgroundLoading="true"/></image>
            </ImageView>

            <Pane styleClass="left-overlay" maxWidth="Infinity" maxHeight="Infinity"/>
            <Pane styleClass="red-divider" maxHeight="Infinity" prefWidth="3"
                  StackPane.alignment="CENTER_LEFT"/>

            <VBox styleClass="left-panel" alignment="TOP_LEFT">

                <VBox styleClass="logo-area" alignment="TOP_LEFT">
                    <Label text="VIS" styleClass="logo-text"/>
                    <Label text="VEHICLE IDENTIFICATION SYSTEM" styleClass="logo-sub"/>
                </VBox>

                <VBox alignment="CENTER_LEFT" VBox.vgrow="ALWAYS" styleClass="tagline-area">
                    <Label text="Identify." styleClass="tagline-line"/>
                    <Label text="Track."    styleClass="tagline-line"/>
                    <Label text="Protect."  styleClass="tagline-line"/>
                    <Label text="Real-time vehicle intelligence for law enforcement,"
                           styleClass="tagline-desc" wrapText="true"/>
                    <Label text="insurance, and fleet management."
                           styleClass="tagline-desc" wrapText="true"/>
                </VBox>

                <HBox styleClass="badge-row" spacing="12">
                    <Label text="SECURE"        styleClass="badge"/>
                    <Label text="LIVE DATABASE" styleClass="badge"/>
                    <Label text="REAL-TIME"     styleClass="badge"/>
                </HBox>

            </VBox>
        </StackPane>

        <!-- RIGHT — Login Form -->
        <VBox styleClass="right-panel" alignment="CENTER" HBox.hgrow="ALWAYS">

            <StackPane styleClass="form-card-stack" maxWidth="460" minWidth="380">

                <VBox styleClass="form-card" alignment="CENTER_LEFT">

                    <Label text="Welcome Back" styleClass="form-title"/>
                    <Label text="Sign in to your account to continue" styleClass="form-subtitle"/>

                    <Region prefHeight="40"/>

                    <Label text="USERNAME" styleClass="field-label"/>
                    <TextField fx:id="usernameField"
                               promptText="Enter your username"
                               styleClass="form-field"/>

                    <Region prefHeight="20"/>

                    <Label text="PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   styleClass="form-field"/>

                    <Region prefHeight="10"/>

                    <Label fx:id="errorLabel" styleClass="error-label"
                           text="" wrapText="true"/>

                    <Region prefHeight="30"/>

                    <Button fx:id="loginButton"
                            text="SIGN IN"
                            styleClass="login-btn"
                            onAction="#handleLogin"
                            maxWidth="Infinity"/>

                    <Region prefHeight="30"/>

                    <HBox alignment="CENTER" spacing="5">
                        <Label text="Don't have an account?" styleClass="note-text"/>
                        <Label text="Contact your administrator" styleClass="note-highlight"/>
                    </HBox>

                </VBox>

                <Pane styleClass="card-accent-top" prefHeight="2" maxHeight="2"
                      maxWidth="340" StackPane.alignment="TOP_CENTER"/>

                <Pane styleClass="corner-tl" prefWidth="14" prefHeight="14"
                      StackPane.alignment="TOP_LEFT" mouseTransparent="true">
                    <StackPane.margin><Insets top="10" left="10"/></StackPane.margin>
                </Pane>
                <Pane styleClass="corner-tr" prefWidth="14" prefHeight="14"
                      StackPane.alignment="TOP_RIGHT" mouseTransparent="true">
                    <StackPane.margin><Insets top="10" right="10"/></StackPane.margin>
                </Pane>
                <Pane styleClass="corner-bl" prefWidth="14" prefHeight="14"
                      StackPane.alignment="BOTTOM_LEFT" mouseTransparent="true">
                    <StackPane.margin><Insets bottom="10" left="10"/></StackPane.margin>
                </Pane>
                <Pane styleClass="corner-br" prefWidth="14" prefHeight="14"
                      StackPane.alignment="BOTTOM_RIGHT" mouseTransparent="true">
                    <StackPane.margin><Insets bottom="10" right="10"/></StackPane.margin>
                </Pane>

            </StackPane>

        </VBox>

    </HBox>

</StackPane>
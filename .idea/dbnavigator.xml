      <console name="VehicleIdentificationDB" type="STANDARD" schema="public" session="Main"><![CDATA[-- ============================================
-- VEHICLE IDENTIFICATION SYSTEM
-- Full Database Schema
-- ============================================

ALTER DATABASE neondb SET search_path TO public;

-- Clean slate if re-running
-- DROP TABLE IF EXISTS insurance_record CASCADE;
-- DROP TABLE IF EXISTS violation CASCADE;
-- DROP TABLE IF EXISTS police_report CASCADE;
-- DROP TABLE IF EXISTS customer_query CASCADE;
-- DROP TABLE IF EXISTS service_record CASCADE;
-- DROP TABLE IF EXISTS vehicle CASCADE;
-- DROP TABLE IF EXISTS customer CASCADE;
-- DROP TABLE IF EXISTS users CASCADE;

-- ============================================
-- 1. USERS (Admin & access control)
-- ======================-- ======================
CREATE TABLE users (
    user_id       SERIAL PRIMARY KEY,
    username      VARCHAR(50) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    role          VARCHAR(20) NOT NULL 
                  CHECK (role IN (
                    'ADMIN','WORKSHOP',
                    'CUSTOMER','POLICE','INSURANCE'
                  )),
    created_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


-- 2. CUSTOMER (Vehicle owners)

CREATE TABLE customer (
    customer_id   SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    address VARCHAR(255),
    phone  VARCHAR(20),
    email  VARCHAR(100) UNIQUE
);

-- ============================================
-- 3. VEHICLE (Core table — everything links here)
-- ============================================
CREATE TABLE vehicle (
    vehicle_id            SERIAL PRIMARY KEY,
    registration_number   VARCHAR(20) UNIQUE NOT NULL,
    make                  VARCHAR(50) NOT NULL,
    model                 VARCHAR(50) NOT NULL,
    year                  INTEGER NOT NULL,
    color                 VARCHAR(30),
    owner_id              INTEGER REFERENCES customer(customer_id)
                          ON DELETE SET NULL
);

-- ============================================
-- 4. SERVICE RECORD (Workshop module)
-- ============================================
CREATE TABLE service_record (
    service_id    SERIAL PRIMARY KEY,
    vehicle_id    INTEGER NOT NULL 
                  REFERENCES vehicle(vehicle_id) 
                  ON DELETE CASCADE,
    service_date  DATE NOT NULL,
    service_type  VARCHAR(100) NOT NULL,
    description   TEXT,
    cost          NUMERIC(10,2)
);

-- ============================================
-- 5. CUSTOMER QUERY (Customer module)
-- ============================================
CREATE TABLE customer_query (
    query_id       SERIAL PRIMARY KEY,
    customer_id    INTEGER NOT NULL 
                   REFERENCES customer(customer_id) 
                   ON DELETE CASCADE,
    vehicle_id     INTEGER NOT NULL 
                   REFERENCES vehicle(vehicle_id) 
                   ON DELETE CASCADE,
    query_date     DATE DEFAULT CURRENT_DATE,
    query_text     TEXT NOT NULL,
    response_text  TEXT
);

-- ============================================
-- 6. POLICE REPORT (Police module)
-- ============================================
CREATE TABLE police_report (
    report_id     SERIAL PRIMARY KEY,
    vehicle_id    INTEGER NOT NULL 
                  REFERENCES vehicle(vehicle_id) 
                  ON DELETE CASCADE,
    report_date   DATE NOT NULL,
    report_type   VARCHAR(50) 
                  CHECK (report_type IN (
                    'Accident','Theft','Suspicious','Other'
                  )),
    description   TEXT,
    officer_name  VARCHAR(100)
);

-- ============================================
-- 7. VIOLATION (Police module)
-- ============================================
CREATE TABLE violation (
    violation_id    SERIAL PRIMARY KEY,
    vehicle_id      INTEGER NOT NULL 
                    REFERENCES vehicle(vehicle_id) 
                    ON DELETE CASCADE,
    violation_date  DATE NOT NULL,
    violation_type  VARCHAR(100) NOT NULL,
    fine_amount     NUMERIC(10,2),
    status          VARCHAR(10) DEFAULT 'Unpaid'
                    CHECK (status IN ('Paid','Unpaid'))
);

-- ============================================
-- 8. INSURANCE RECORD (Insurance module)
-- ============================================
CREATE TABLE insurance_record (
    insurance_id    SERIAL PRIMARY KEY,
    vehicle_id      INTEGER NOT NULL 
                    REFERENCES vehicle(vehicle_id) 
                    ON DELETE CASCADE,
    provider_name   VARCHAR(100) NOT NULL,
    policy_number   VARCHAR(50) UNIQUE NOT NULL,
    start_date      DATE NOT NULL,
    end_date        DATE NOT NULL,
    premium_amount  NUMERIC(10,2),
    status          VARCHAR(20) DEFAULT 'Active'
                    CHECK (status IN ('Active','Expired','Cancelled'))
);

-- ============================================
-- STORED PROCEDURES (Required by assignment)
-- ============================================

-- Procedure: Add a new vehicle with owner
CREATE OR REPLACE PROCEDURE add_vehicle(
    p_reg       VARCHAR,
    p_make      VARCHAR,
    p_model     VARCHAR,
    p_year      INTEGER,
    p_color     VARCHAR,
    p_owner_id  INTEGER
)
LANGUAGE plpgsql AS $$
BEGIN
    INSERT INTO vehicle(
        registration_number, make, model, 
        year, color, owner_id
    )
    VALUES(
        p_reg, p_make, p_model, 
        p_year, p_color, p_owner_id
    );
END;
$$;

-- Procedure: Update violation status
CREATE OR REPLACE PROCEDURE update_violation_status(
    p_violation_id  INTEGER,
    p_status        VARCHAR
)
LANGUAGE plpgsql AS $$
BEGIN
    UPDATE violation
    SET status = p_status
    WHERE violation_id = p_violation_id;
END;
$$;

-- Procedure: Respond to customer query
CREATE OR REPLACE PROCEDURE respond_to_query(
    p_query_id   INTEGER,
    p_response   TEXT
)
LANGUAGE plpgsql AS $$
BEGIN
    UPDATE customer_query
    SET response_text = p_response
    WHERE query_id = p_query_id;
END;
$$;

-- ============================================
-- VIEWS (Required by assignment)
-- ============================================

-- View: Full vehicle details with owner
CREATE OR REPLACE VIEW vehicle_details AS
SELECT 
    v.vehicle_id,
    v.registration_number,
    v.make,
    v.model,
    v.year,
    v.color,
    c.name        AS owner_name,
    c.phone       AS owner_phone,
    c.email       AS owner_email
FROM vehicle v
LEFT JOIN customer c ON v.owner_id = c.customer_id;

-- View: Active insurance policies
CREATE OR REPLACE VIEW active_insurance AS
SELECT 
    i.insurance_id,
    v.registration_number,
    v.make,
    v.model,
    i.provider_name,
    i.policy_number,
    i.end_date,
    i.premium_amount
FROM insurance_record i
JOIN vehicle v ON i.vehicle_id = v.vehicle_id
WHERE i.status = 'Active';

-- View: Unpaid violations with vehicle info
CREATE OR REPLACE VIEW unpaid_violations AS
SELECT 
    vl.violation_id,
    v.registration_number,
    v.make,
    v.model,
    vl.violation_date,
    vl.violation_type,
    vl.fine_amount
FROM violation vl
JOIN vehicle v ON vl.vehicle_id = v.vehicle_id
WHERE vl.status = 'Unpaid';

